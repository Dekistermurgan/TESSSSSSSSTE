        return oldShootFunction(self, ...)
    end)

    -- // --- LÓGICA ESP DE JOGADORES ---
    local function CreateESP(plr)
        local Box = Drawing.new("Square")
        local Tracer = Drawing.new("Line")
        local Name = Drawing.new("Text")
        local Dot = Drawing.new("Circle")

        local function Update()
            local connection
            connection = RunService.RenderStepped:Connect(function()
                if ESP_Settings.Enabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr ~= LocalPlayer then
                    local Root = plr.Character.HumanoidRootPart
                    local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                    
                    if OnScreen then
                        local isTeam = plr.Team == LocalPlayer.Team
                        if isTeam and not ESP_Settings.ShowTeam then
                            Box.Visible = false Tracer.Visible = false Name.Visible = false Dot.Visible = false
                            return
                        end

                        local Color = (isTeam and ESP_Settings.ShowTeamColor) and Color3.new(0,1,0) or Color3.new(1,0,0)
                        local Dist = (Camera.CFrame.Position - Root.Position).Magnitude

                        Box.Visible = ESP_Settings.ShowBoxes
                        Box.Color = Color
                        Box.Size = Vector2.new(2000 / Pos.Z, 2500 / Pos.Z)
                        Box.Position = Vector2.new(Pos.X - Box.Size.X / 2, Pos.Y - Box.Size.Y / 2)

                        Tracer.Visible = ESP_Settings.ShowTracers
                        Tracer.Color = Color
                        Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        Tracer.To = Vector2.new(Pos.X, Pos.Y)

                        Name.Visible = ESP_Settings.ShowNames
                        Name.Outline = ESP_Settings.TextOutline
                        local textStr = plr.Name
                        if ESP_Settings.ShowDistance then textStr = textStr .. " [" .. math.floor(Dist) .. "m]" end
                        if ESP_Settings.ShowHealth and plr.Character:FindFirstChild("Humanoid") then 
                            textStr = textStr .. " (" .. math.floor(plr.Character.Humanoid.Health) .. "%)" 
                        end
                        Name.Text = textStr
                        Name.Position = Vector2.new(Pos.X, Pos.Y - Box.Size.Y / 2 - 20)
                        Name.Center = true

                        local Head = plr.Character:FindFirstChild("Head")
                        if Head then
                            local HeadPos = Camera:WorldToViewportPoint(Head.Position)
                            Dot.Visible = ESP_Settings.ShowHeadDot
                            Dot.Color = Color
                            Dot.Position = Vector2.new(HeadPos.X, HeadPos.Y)
                            Dot.Radius = 500 / Pos.Z
                        end
                    else
                        Box.Visible = false Tracer.Visible = false Name.Visible = false Dot.Visible = false
                    end
                else
                    Box.Visible = false Tracer.Visible = false Name.Visible = false Dot.Visible = false
                    if not plr.Parent then connection:Disconnect() end
                end
            end)
        end
        coroutine.wrap(Update)()
    end

    for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
