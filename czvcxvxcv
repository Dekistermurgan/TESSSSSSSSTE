-- [[ LÓGICA CORRIGIDA ]]
local isJumping = false
local jumpStartTime = 0
local jumpStartY = 0

-- Detectar Pulo (Fora do loop para não lagar)
UserInputService.JumpRequest:Connect(function()
    if not stepEnabled then return end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp and not isJumping then
        local down = workspace:Raycast(hrp.Position, Vector3.new(0, -5, 0), rayParams)
        if down then
            isJumping = true
            jumpStartTime = tick()
            jumpStartY = hrp.Position.Y
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not stepEnabled then return end -- Se o toggle estiver off, o script não faz nada
    
    local char = player.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end

    rayParams.FilterDescendantsInstances = {char}
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist

    local pos = hrp.Position
    local halfY = hrp.Size.Y / 2
    local dir = humanoid.MoveDirection
    local finalY = pos.Y

    -- Pulo
    if isJumping then
        local elapsed = tick() - jumpStartTime
        if elapsed < JUMP_TIME then
            local t = elapsed / JUMP_TIME
            finalY = jumpStartY + (4 * JUMP_HEIGHT * t * (1 - t))
        else
            isJumping = false
        end
    else
        local down = workspace:Raycast(pos, Vector3.new(0, -200, 0), rayParams)
        local groundY = down and (down.Position.Y + halfY + HEIGHT_OFFSET) or (pos.Y + HEIGHT_OFFSET)
        finalY = math.max(pos.Y, groundY)
    end

    -- Step
    if dir.Magnitude > 0 and not isJumping then
        local forward = dir.Unit * FORWARD_DIST
        local footPos = pos - Vector3.new(0, halfY - 0.1, 0)
        local wallCheck = workspace:Raycast(footPos, forward, rayParams)

        if wallCheck then
            local normal = wallCheck.Normal
            local angle = math.deg(math.acos(normal:Dot(Vector3.new(0, 1, 0))))
            
            if angle < MAX_CLIMB_ANGLE then
                local aboveWallOrigin = footPos + forward + Vector3.new(0, STEP_CHECK_Y, 0)
                local aboveCheck = workspace:Raycast(aboveWallOrigin, Vector3.new(0, -STEP_CHECK_Y*2, 0), rayParams)

                if aboveCheck then
                    local topY = aboveCheck.Position.Y + halfY + HEIGHT_OFFSET
                    if topY - finalY <= STEP_HEIGHT then
                        finalY = topY
                    end
                end
            end
        end
    end

    -- Aplica o CFrame (Incluindo a rotação de 180 que você tinha)
    hrp.CFrame = CFrame.new(pos.X, finalY, pos.Z) * CFrame.Angles(math.rad(180), 0, 0)
end)

