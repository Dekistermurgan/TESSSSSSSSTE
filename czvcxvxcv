local function createCharacterClone()
    if not localPlayer.Character then return nil end
    local character = localPlayer.Character
    local clone = Instance.new("Model")
    clone.Name = "CharacterClone"
    clone.Parent = workspace
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local newPart = part:Clone()
            newPart.Parent = clone
            newPart.Anchored = true
            newPart.CanCollide = false
            newPart.CFrame = part.CFrame
            
            for _, child in ipairs(newPart:GetDescendants()) do
                if child:IsA("Script") or child:IsA("LocalScript") then
                    child:Destroy()
                end
            end
        elseif part:IsA("MeshPart") or part:IsA("Part") then
            local newPart = part:Clone()
            newPart.Parent = clone
            newPart.Anchored = true
            newPart.CanCollide = false
            newPart.CFrame = part.CFrame
        end
    end
    
    local root = clone:FindFirstChild("HumanoidRootPart") or clone:FindFirstChild("Torso") or clone:FindFirstChild("UpperTorso")
    if root then
        local billboard = Instance.new("BillboardGui", root)
        billboard.Name = "NameBillboard"
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        
        local nameLabel = Instance.new("TextLabel", billboard)
        nameLabel.Size = UDim2.new(1, 0, 1, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = localPlayer.Name
        nameLabel.TextColor3 = Color3.new(1, 1, 0)
        nameLabel.TextStrokeTransparency = 0
        nameLabel.Font = Enum.Font.SourceSansBold
        nameLabel.TextScaled = true
    end

    local humanoid = Instance.new("Humanoid", clone)
    humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    
    return clone
end

local function createPlayerName()
    if not localPlayer.Character then return nil end
    local character = localPlayer.Character
    local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    
    if root then
