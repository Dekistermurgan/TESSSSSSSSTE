    local BACK_KEY    = Enum.KeyCode.S
    local LEFT_KEY    = Enum.KeyCode.A
    local RIGHT_KEY   = Enum.KeyCode.D
    local UP_KEYS     = { Enum.KeyCode.L }
    local DOWN_KEYS   = { Enum.KeyCode.K }

    local HORIZONTAL_SPEED = 80
    local ASCEND_SPEED     = 60
    local SMOOTHNESS       = 1
