    -- // --- FUNÇÃO DE VALIDAÇÃO ---
    local function isValidKillTarget(player)
        if player == LocalPlayer then return false end
        if not player.Character or not player.Character:FindFirstChild("Humanoid") then return false end
        
        local humanoid = player.Character.Humanoid
        if humanoid.Health <= 0 then return false end
        
        -- Verifica o time
        if teamCheckActive and player.Team == LocalPlayer.Team then return false end 
        
        return true
    end

    -- // --- FUNÇÃO EXECUTORA (KILL ALL) ---
    local function doKillAll()
        for _, player in ipairs(Players:GetPlayers()) do
            if not killAllEnabled then break end
            
            if isValidKillTarget(player) then
                local character = player.Character
                local targetPart = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
                
                if targetPart then
                    pcall(function()
                        -- Simula o disparo para o servidor
                        ShootEvent:FireServer("Weapon", false, false)
                        
                        -- Envia o evento de dano
                        local damageArgs = {
                            0.9209483679665256,
                            targetPart,
                            24.339837646484376,
                            targetPart.Position
                        }
                        DamageEvent:FireServer(unpack(damageArgs))
                    end)
                    task.wait(FIRE_RATE)
                end
            end
        end
    end

