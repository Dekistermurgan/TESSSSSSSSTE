-- [[ CONFIGURAÇÕES ORIGINAIS ]]
local HEIGHT_OFFSET    = 0.3
local FORWARD_DIST     = 2
local STEP_HEIGHT      = 4
local STEP_CHECK_Y     = 3
local MAX_CLIMB_ANGLE  = 80
local JUMP_HEIGHT      = 7.2
local JUMP_TIME        = 0.5
local rayParams        = RaycastParams.new()

-- [[ INTERFACE LINORIA ]]


