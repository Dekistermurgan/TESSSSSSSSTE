    local function findVehicleModelFromPart(part)
        if not part then return nil end
        local cur = part
        while cur and cur.Parent do
            if cur.Parent == SPAWNED_VEHICLES_FOLDER then
                if cur:IsA("Model") then
                    return cur
                end
            end
            cur = cur.Parent
        end
        return nil
    end

    local function getPrimaryPart(model)
        if not model then return nil end
        if model.PrimaryPart and model.PrimaryPart:IsA("BasePart") then
            return model.PrimaryPart
        end
        for _,v in ipairs(model:GetDescendants()) do
            if v:IsA("BasePart") then
                model.PrimaryPart = v
                return v
            end
        end
        return nil
    end

    local function isVehicleValidForFly(model)
        if not model then return false end
        if not model.Parent then return false end
        if model.Parent ~= SPAWNED_VEHICLES_FOLDER then return false end
        return true
    end

    local function refreshCurrentVehicleFromSeat(seatPart)
        if not seatPart then
            currentVehicle = nil
            currentSeat = nil
            return
        end
        local model = findVehicleModelFromPart(seatPart)
        if model and isVehicleValidForFly(model) then
            currentVehicle = model
            currentSeat = seatPart
        else
            currentVehicle = nil
            currentSeat = nil
        end
    end

    local function getModelMass(model)
        if not model then return 0 end
        local total = 0
        for _,obj in ipairs(model:GetDescendants()) do
            if obj:IsA("BasePart") then
                local ok, m = pcall(function() return obj:GetMass() end)
                if ok then
                    total += m
                end
            end
        end
        return total
    end

    local function ensureHoverForce(model)
        if bodyForces[model] then return end
        local primary = getPrimaryPart(model)
        if not primary then return end

        local mass = getModelMass(model)
        local gravity = workspace.Gravity
        local bf = Instance.new("BodyForce")
        bf.Force = Vector3.new(0, mass * gravity, 0)
        bf.Parent = primary

        bodyForces[model] = bf
    end

    local function removeHoverForce(model)
        local bf = bodyForces[model]
        if bf then
            bf:Destroy()
            bodyForces[model] = nil
        end
    end

