    RunService.RenderStepped:Connect(function(dt)
        if not flyingEnabled or not carFlyEnabled then return end
        if not currentVehicle then return end

        local primary = getPrimaryPart(currentVehicle)
        if not primary then return end

        ensureHoverForce(currentVehicle)

        local forward, right, up = 0,0,0

        if pressed[FORWARD_KEY] then forward += 1 end
        if pressed[BACK_KEY] then forward -= 1 end
        if pressed[RIGHT_KEY] then right += 1 end
        if pressed[LEFT_KEY] then right -= 1 end

        for _,k in ipairs(UP_KEYS) do
            if pressed[k] then up += 1 end
        end

        for _,k in ipairs(DOWN_KEYS) do
            if pressed[k] then up -= 1 end
        end

        local cam = Camera.CFrame
        local forwardDir = Vector3.new(cam.LookVector.X,0,cam.LookVector.Z).Unit
        local rightDir = Vector3.new(cam.RightVector.X,0,cam.RightVector.Z).Unit

        local moveVec =
            (forwardDir * forward * HORIZONTAL_SPEED) +
            (rightDir * right * HORIZONTAL_SPEED) +
            Vector3.new(0, up * ASCEND_SPEED, 0)

        primary.AssemblyLinearVelocity = moveVec
        primary.AssemblyAngularVelocity = Vector3.zero
    end)

