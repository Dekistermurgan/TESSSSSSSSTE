RunService.RenderStepped:Connect(function()
    if not localPlayer.Character or not localPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local torso = localPlayer.Character.HumanoidRootPart
    local humanoid = localPlayer.Character:WaitForChild("Humanoid")

    if manipToggle and not flying then
        flying = true
        originalCFrame = torso.CFrame
        startPosition = torso.Position
        
        anchorPart = Instance.new("Part", workspace)
        anchorPart.Name = "AnchorPart"
        anchorPart.Anchored = true
        anchorPart.CanCollide = true
        anchorPart.Transparency = 1
        anchorPart.Size = Vector3.new(1, 1, 1)
        anchorPart.CFrame = torso.CFrame * CFrame.new(0, -10, 0)

        local weld = Instance.new("WeldConstraint", anchorPart)
        weld.Part0 = anchorPart
        weld.Part1 = torso
        humanoid.PlatformStand = true
    elseif not manipToggle and flying then
        flying = false
        if anchorPart then anchorPart:Destroy() end
        humanoid.PlatformStand = false
        if originalCFrame then torso.CFrame = originalCFrame end
    end

    if flying then
        torso.Anchored = false
        local camera = workspace.CurrentCamera
        local moveVector = Vector3.new()
        
        -- Puxa a velocidade diretamente do Slider da Linoria
        local currentSpeed = Options.GhostSpeed.Value

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector += camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector -= camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector -= camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector += camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector += Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector -= Vector3.new(0, 1, 0) end
        
        if moveVector.Magnitude > 0 then
            torso.CFrame += moveVector.Unit * currentSpeed
        end
        
        anchorPart.CFrame = torso.CFrame * CFrame.new(0, -10, 0)

        local distance = (torso.Position - startPosition).Magnitude
        distanceLabel.Text = ("Distância: %.2f studs"):format(distance)
    end
end)

